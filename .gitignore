# ==============================
# DATA FILES (DO NOT UPLOAD)
# ==============================
data/*.csv
data/*.xlsx
data/*.xls

# Keep structure + sample
!data/.gitkeep
!data/README.md
!data/sample_data.csv

# ==============================
# MODEL FILES (large binaries)
# ==============================
models/*.pkl
models/*.h5
models/*.joblib

# Keep structure
!models/.gitkeep

# ==============================
# RESULTS (generated outputs)
# ==============================
results/*.png
results/*.jpg
results/*.pdf

# ✅ Allow ONLY README charts
!results/readme_charts/
!results/readme_charts/*.png
!results/readme_charts/*.jpg

# Keep structure
!results/.gitkeep

# ==============================
# LOGS
# ==============================
logs/*.log
logs/*.txt

# Keep structure
!logs/.gitkeep

# ==============================
# ENVIRONMENT / SECRETS
# ==============================
.env
.env.local
credentials.json
secrets.json

